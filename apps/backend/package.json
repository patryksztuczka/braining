{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "check-types": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md}\"",
    "lint": "eslint . --max-warnings 0",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:migrate:local": "wrangler d1 migrations apply braining-prod --local",
    "db:studio": "npx drizzle-kit studio"
  },
  "dependencies": {
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@types/node": "^24.12.0",
    "@vitest/coverage-istanbul": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.1",
    "wrangler": "^4.4.0"
  }
}
